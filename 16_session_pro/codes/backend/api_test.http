@baseUrl = http://localhost:3000

### ──────────────────────────────────────
### 注册接口
### ──────────────────────────────────────

### 注册管理员用户（group_id: 1 = admin）
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
    "username": "admin",
    "password": "cisco123",
    "email": "admin@example.com",
    "group_id": 1
}

### 注册普通用户（group_id: 3 = user）
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
    "username": "jack",
    "password": "cisco123",
    "email": "jack@example.com",
    "group_id": 3
}

### 注册失败：用户名已存在（期望 500）
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
    "username": "admin",
    "password": "cisco123",
    "email": "admin2@example.com",
    "group_id": 1
}

### 注册失败：缺少必填字段（期望 400）
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
    "username": "bob"
}

### ──────────────────────────────────────
### 登录接口
### ──────────────────────────────────────

### 登录成功（管理员）
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
    "username": "admin",
    "password": "cisco123"
}

### 登录成功（普通用户）
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
    "username": "jack",
    "password": "cisco123"
}

### 登录失败：密码错误（期望 401）
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
    "username": "admin",
    "password": "wrongpassword"
}

### 登录失败：用户不存在（期望 401）
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
    "username": "nobody",
    "password": "cisco123"
}

### 登录失败：缺少必填字段（期望 400）
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
    "username": "admin"
}
