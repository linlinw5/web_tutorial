{
    "compilerOptions": {
        "target": "es2020",
        "module": "es2020",
        "rootDir": "./src",
        "outDir": "./dist",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "rewriteRelativeImportExtensions": true,
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true
    }
}
