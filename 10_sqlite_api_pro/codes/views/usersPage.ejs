<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <h1><%= title %></h1>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Email</th>
            </tr>
        </thead>
        <tbody>
            <% content.data.forEach(user => { %>
                <tr>
                    <td><%= user.id %></td>
                    <td><%= user.username %></td>
                    <td><%= user.email %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <!-- 分页导航：每个页码是一个 <a> 链接，点击触发完整页面刷新 -->
    <ul>
        <% for(let i = 1; i <= pagination.totalPages; i++) { %>
            <li>
                <% if (i === pagination.currentPage) { %>
                    <strong>Page <%= i %></strong>
                <% } else { %>
                    <a href="/users?limit=<%= pagination.limit %>&offset=<%= pagination.limit * (i - 1) %>">Page <%= i %></a>
                <% } %>
            </li>
        <% } %>
    </ul>
</body>
</html>
