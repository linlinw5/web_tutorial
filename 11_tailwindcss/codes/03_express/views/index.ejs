<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/output.css" />
  </head>
  <body>
    <h1 class="text-2xl text-red-500"><%= title %></h1>
    <p class="text-red-500 bg-green-100">Just taking a quick look</p>
    <button id="btn" class="btn-primay">1235556</button>
    <script>
      console.log("Hello, Tailwind CSS with Express and EJS!");
      const btn = document.getElementById("btn");
      btn?.addEventListener("click", () => {
        alert("Button clicked!");
      });
    </script>
  </body>
</html>
