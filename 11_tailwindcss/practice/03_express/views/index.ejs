<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <!-- Import compiled CSS (note: static files served by Express use absolute path /css/output.css) -->
    <link rel="stylesheet" href="/css/output.css" />
  </head>
  <body>
    <!-- Style the following elements with Tailwind utility classes -->

    <!-- 1. Title: 2xl size, red text -->
    <h1><%= title %></h1>

    <!-- 2. Paragraph: red text, light green background -->
    <p>Hello from EJS + Tailwind!</p>

    <!-- 3. Define .btn-primary in input.css and use it here -->
    <button id="btn">Click Me</button>

    <script>
      const btn = document.getElementById("btn");
      btn?.addEventListener("click", () => {
        alert("Button clicked!");
      });
    </script>
  </body>
</html>
