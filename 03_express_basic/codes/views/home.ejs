<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <img src="/images/logo.jpg" alt="logo">
    <h1><%= title %></h1>
    <ul>
        <% for (let blog of blogs) { %>
           <li>
                <h2><a href="/blog/?id=<%= blog.id %>"><%= blog.title %></a></h2>
            </li>
        <% } %>
    </ul>
</body>
</html>
